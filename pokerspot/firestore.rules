rules_version = '2';

// PokerSpot production rules (Plan 7-B) — replaces test mode.
// Authorization reads the caller's users/{uid} doc (role/clubId/blocked).
// Custom claims arrive with Plan 7-A Cloud Functions; until then these get()s
// are the source of truth.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function role() {
      return signedIn() ? userDoc().role : 'anon';
    }
    function isBlocked() {
      return signedIn() && userDoc().get('blocked', false) == true;
    }
    // Accept snake_case (canonical) + legacy enum-name role strings.
    function isAdmin() {
      return signedIn() && (role() == 'super_admin' || role() == 'superadmin');
    }
    function isPitboss() {
      return signedIn() && (role() == 'pit_boss' || role() == 'pitboss');
    }
    function myClub() {
      return userDoc().get('clubId', '');
    }

    // ---- Users -------------------------------------------------------------
    match /users/{uid} {
      // Read your own doc; admins read anyone; Pit Bosses read users so they can
      // search registered players by name/phone when seating them on the floor.
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin() || isPitboss());
      // First onboarding writes your own doc.
      allow create: if signedIn() && request.auth.uid == uid;
      // You update your own profile (unless blocked); admins update anyone.
      allow update: if isAdmin() || (request.auth.uid == uid && !isBlocked());
      allow delete: if isAdmin();
    }

    // ---- Clubs (+ tables subcollection) ------------------------------------
    match /clubs/{clubId} {
      allow read: if signedIn() &&
        (resource.data.enabled == true || isAdmin() || (isPitboss() && myClub() == clubId));
      allow create, delete: if isAdmin();
      // Admin edits anything; a Pit Boss may change ONLY their own club's
      // reservationMinutes (the configurable reservation hold length).
      allow update: if isAdmin()
        || (isPitboss() && myClub() == clubId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reservationMinutes']));

      match /tables/{tableId} {
        allow read: if signedIn() && !isBlocked();
        allow write: if isAdmin() || (isPitboss() && myClub() == clubId);
      }

      match /announcements/{id} {
        // Any signed-in user may read a club's announcements (broadcast feed).
        allow read: if signedIn() && !isBlocked();
        // Only the club's Pit Boss (or Admin) may post / edit / delete.
        allow create, update, delete: if isAdmin()
          || (isPitboss() && myClub() == clubId);
      }
    }

    // ---- Waitlist ----------------------------------------------------------
    match /waitlist/{id} {
      allow read: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid);
      // Player joins for themselves; a Pit Boss / Admin may add anyone (a
      // registered player or a walk-in) to their own club's waitlist.
      allow create: if signedIn() && !isBlocked()
        && (request.resource.data.playerUid == request.auth.uid
            || isAdmin()
            || (isPitboss() && request.resource.data.clubId == myClub()));
      // Player edits own (cancel); Pit Boss/Admin manage their club's.
      allow update: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid && !isBlocked());
      allow delete: if isAdmin();
    }

    // ---- Sessions ----------------------------------------------------------
    match /sessions/{id} {
      allow read: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid);
      // Created/ended by the club's Pit Boss (or Admin).
      allow create: if isAdmin() || (isPitboss() && request.resource.data.clubId == myClub());
      allow update: if isAdmin() || (isPitboss() && resource.data.clubId == myClub());
      allow delete: if isAdmin();
    }

    // ---- Reservations (instant 30-min hold) --------------------------------
    match /reservations/{id} {
      allow read: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid);
      allow create: if signedIn() && !isBlocked()
        && request.resource.data.playerUid == request.auth.uid;
      // Player cancels own; Pit Boss/Admin mark arrived for their club.
      allow update: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid && !isBlocked());
      allow delete: if isAdmin();
    }

    // ---- Admin audit log ---------------------------------------------------
    match /admin_audit_log/{id} {
      allow read: if isAdmin();
      // Append-only: admins + pit bosses log their actions; never edited.
      allow create: if isAdmin() || isPitboss();
      allow update, delete: if false;
    }

    // ---- 1-on-1 chat (flat; thread = clubId + playerUid) -------------------
    match /messages/{id} {
      allow read: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid);
      // Sender must be the caller; you may only post into your own thread
      // (player) or your own club's threads (Pit Boss / Admin).
      allow create: if signedIn() && !isBlocked()
        && request.resource.data.senderUid == request.auth.uid
        && (request.resource.data.playerUid == request.auth.uid
            || (isPitboss() && request.resource.data.clubId == myClub())
            || isAdmin());
      // The recipient marks messages read (read flag); only admins delete.
      allow update: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ---- Account deletion requests (GDPR / App Store) ----------------------
    // A user requests deletion of their OWN account; the cascade (data + Auth)
    // runs server-side in the onAccountDeletion function (admin SDK bypasses
    // rules), so clients may only create their own request.
    match /deletion_requests/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
    }

    // ---- Tournaments (announced by a club; everyone signed in may read) ------
    match /tournaments/{id} {
      allow read: if signedIn();
      allow create: if isAdmin()
        || (isPitboss() && request.resource.data.clubId == myClub());
      allow update, delete: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub());
    }

    // ---- Tournament sign-ups (registration + waitlist) ---------------------
    // Read by anyone signed in (so the registered / waitlist counts are visible
    // to all). A player creates only their own sign-up. Seat vs. waitlist is
    // derived from createdAt ordering (no stored status), so docs are immutable.
    match /tournament_registrations/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && !isBlocked()
        && request.resource.data.playerUid == request.auth.uid;
      allow update: if false;
      // A player removes their own sign-up; the club's Pit Boss / Admin may too.
      allow delete: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid && !isBlocked());
    }
  }
}
