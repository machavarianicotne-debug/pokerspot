rules_version = '2';

// PokerSpot production rules (Plan 7-B) — replaces test mode.
// Authorization reads the caller's users/{uid} doc (role/clubId/blocked).
// Custom claims arrive with Plan 7-A Cloud Functions; until then these get()s
// are the source of truth.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function role() {
      return signedIn() ? userDoc().role : 'anon';
    }
    function isBlocked() {
      return signedIn() && userDoc().get('blocked', false) == true;
    }
    // Accept snake_case (canonical) + legacy enum-name role strings.
    function isAdmin() {
      return signedIn() && (role() == 'super_admin' || role() == 'superadmin');
    }
    function isPitboss() {
      return signedIn() && (role() == 'pit_boss' || role() == 'pitboss');
    }
    function myClub() {
      return userDoc().get('clubId', '');
    }

    // ---- Users -------------------------------------------------------------
    match /users/{uid} {
      // Read your own doc; admins read anyone; Pit Bosses read users so they can
      // search registered players by name/phone when seating them on the floor.
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin() || isPitboss());
      // First onboarding writes your own doc.
      allow create: if signedIn() && request.auth.uid == uid;
      // You update your own profile (unless blocked); admins update anyone.
      allow update: if isAdmin() || (request.auth.uid == uid && !isBlocked());
      allow delete: if isAdmin();
    }

    // ---- Clubs (+ tables subcollection) ------------------------------------
    match /clubs/{clubId} {
      allow read: if signedIn() &&
        (resource.data.enabled == true || isAdmin() || (isPitboss() && myClub() == clubId));
      allow write: if isAdmin();

      match /tables/{tableId} {
        allow read: if signedIn() && !isBlocked();
        allow write: if isAdmin() || (isPitboss() && myClub() == clubId);
      }
    }

    // ---- Waitlist ----------------------------------------------------------
    match /waitlist/{id} {
      allow read: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid);
      // Player joins for themselves (not blocked).
      allow create: if signedIn() && !isBlocked()
        && request.resource.data.playerUid == request.auth.uid;
      // Player edits own (cancel); Pit Boss/Admin manage their club's.
      allow update: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid && !isBlocked());
      allow delete: if isAdmin();
    }

    // ---- Sessions ----------------------------------------------------------
    match /sessions/{id} {
      allow read: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid);
      // Created/ended by the club's Pit Boss (or Admin).
      allow create: if isAdmin() || (isPitboss() && request.resource.data.clubId == myClub());
      allow update: if isAdmin() || (isPitboss() && resource.data.clubId == myClub());
      allow delete: if isAdmin();
    }

    // ---- Reservations (instant 30-min hold) --------------------------------
    match /reservations/{id} {
      allow read: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid);
      allow create: if signedIn() && !isBlocked()
        && request.resource.data.playerUid == request.auth.uid;
      // Player cancels own; Pit Boss/Admin mark arrived for their club.
      allow update: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid && !isBlocked());
      allow delete: if isAdmin();
    }

    // ---- Admin audit log ---------------------------------------------------
    match /admin_audit_log/{id} {
      allow read: if isAdmin();
      // Append-only: admins + pit bosses log their actions; never edited.
      allow create: if isAdmin() || isPitboss();
      allow update, delete: if false;
    }

    // ---- 1-on-1 chat (flat; thread = clubId + playerUid) -------------------
    match /messages/{id} {
      allow read: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid);
      // Sender must be the caller; you may only post into your own thread
      // (player) or your own club's threads (Pit Boss / Admin).
      allow create: if signedIn() && !isBlocked()
        && request.resource.data.senderUid == request.auth.uid
        && (request.resource.data.playerUid == request.auth.uid
            || (isPitboss() && request.resource.data.clubId == myClub())
            || isAdmin());
      // The recipient marks messages read (read flag); only admins delete.
      allow update: if isAdmin()
        || (isPitboss() && resource.data.clubId == myClub())
        || (signedIn() && resource.data.playerUid == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
